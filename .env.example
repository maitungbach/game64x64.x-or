# Port app Node.js
PORT=3000

# Muc dich su dung khi deploy
NODE_ENV=production

# Bat Redis cho multi-server (true/false)
ENABLE_REDIS=false

# URL Redis dung chung cho cac node
REDIS_URL=redis://:ColorBox64x64_Redis_2026@172.16.10.202:6379

# MongoDB cho auth (neu co)
MONGO_URL=
MONGO_DB_NAME=game64x64

# Khong yeu cau MongoDB cho auth (dieu nay cho phep luu tru in-memory)
AUTH_REQUIRE_MONGO=false

# Khoa luu players trong Redis
REDIS_PLAYERS_KEY=game64x64:players

# Nhip gop broadcast updatePlayers (ms), giam tai khi nhieu move
BROADCAST_INTERVAL_MS=33

# Gioi han tan suat move / socket (ms)
MOVE_INTERVAL_MS=16

# Tan suat phat snapshot toan bo player list (ms)
SNAPSHOT_INTERVAL_MS=250

# Bao ve endpoint /api/stats (de trong nghia la khong bao ve)
STATS_TOKEN=

# Danh sach email co quyen admin cho /admin va /api/health
# Cach nhau boi dau phay, vi du: ADMIN_EMAILS=admin@example.com,ops@example.com
ADMIN_EMAILS=

# Auth backend
AUTH_COOKIE_NAME=game64x64_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_SEC=86400
STRICT_CLUSTER_CONFIG=true
ALLOW_LOOPBACK_MONGO_TUNNEL=true
AUTH_REQUIRE_MONGO=true
AUTH_REJECT_CONCURRENT=false
AUTH_RELEASE_DELAY_MS=60000
AUTH_SEED_TEST_USERS=true
AUTH_ALLOW_CONCURRENT_SEED_USERS=true
AUTH_LOGIN_FAIL_RATE_LIMIT_MAX=10
AUTH_LOGIN_FAIL_RATE_LIMIT_WINDOW_SEC=300
AUTH_REGISTER_RATE_LIMIT_MAX=15
AUTH_REGISTER_RATE_LIMIT_WINDOW_SEC=600
REDIS_USERS_KEY=game64x64:users
REDIS_SESSION_PREFIX=game64x64:session:
REDIS_USER_SESSION_PREFIX=game64x64:user-session:
