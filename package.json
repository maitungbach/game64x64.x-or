{
  "name": "game64x64-x-or",
  "version": "1.0.0",
  "private": true,
  "description": "San choi sac mau 64x64 - Giai doan 5 multi-server",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "pm2:start": "pm2 start config/ecosystem.config.js",
    "pm2:restart": "pm2 restart game64x64",
    "pm2:stop": "pm2 stop game64x64",
    "windows:ensure-runtime": "powershell -ExecutionPolicy Bypass -File scripts/windows-run-ensure-runtime.ps1",
    "windows:watch-runtime": "powershell -ExecutionPolicy Bypass -File scripts/windows-runtime-watchdog.ps1",
    "windows:install-startup": "powershell -ExecutionPolicy Bypass -File scripts/windows-install-startup.ps1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:smoke": "node tests/realtime-smoke.test.js",
    "test:rooms": "node tests/room-service.test.js",
    "test:auth": "node tests/auth-smoke.test.js",
    "test:stats": "node tests/stats-smoke.test.js",
    "test:config": "node tests/config-guard.test.js",
    "test:redis": "node tests/redis-atomic.test.js",
    "test:all": "npm run test:smoke && npm run test:rooms && npm run test:auth && npm run test:stats && npm run test:config && npm run test:redis",
    "test:load": "node scripts/load-test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "express": "^4.21.2",
    "mongodb": "^6.14.2",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1"
  }
}
